# NVIDIA NIM API Configuration
# Get your API key from: https://build.nvidia.com/
NVAPI_KEY=nvapi-xxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Baidu AI Search API Configuration
# Get your API key from: https://console.bce.baidu.com/ai-search/qianfan/ais/console/apiKey
BAIDU_API_KEY_1=your_baidu_api_key_1
BAIDU_API_KEY_2=your_baidu_api_key_2

# Serper.dev API Configuration
# Get your API key from: https://serper.dev/
SERPER_API_KEY_1=your_serper_api_key_1
SERPER_API_KEY_2=your_serper_api_key_2
